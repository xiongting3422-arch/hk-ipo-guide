# 富途 LLM 网关（llmClient.js）
LLM_GATEWAY_URL=https://llm-proxy.futuoa.com/aws
LLM_GATEWAY_KEY=your-gateway-key
LLM_MODEL_ID=claude-sonnet-4-6
# 可选：逗号分隔时默认取第一个；也可单独指定 claude-opus-4-7
# LLM_MODEL_ID=claude-sonnet-4-6,claude-opus-4-7
# LLM_API_PATH=/v1/messages

# IPO 增量审计（scripts/run-ipo-audit.js）
# IPO_ANALYSIS_STORE_PATH=data/ipo-analysis-db.json
# GITHUB_BRANCH=main
# GITHUB_TOKEN=ghp_xxx   # 可选；脚本默认用本地 git push 凭据
IPO_API_PORT=8788
# IPO_SHEET_PUBLISH_BASE=https://docs.google.com/spreadsheets/d/e/.../pub
# IPO_SHEET_LISTED_GID=63719317
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.25
